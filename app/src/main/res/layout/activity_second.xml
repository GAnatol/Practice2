<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:expandableTextView="http://android.com"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_fon"
    android:fillViewport="true">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/my_name"
            android:textColor="@color/white_blckthme"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginBottom="16dp"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layoutAnimation="@anim/falldown"
            android:padding="1dp">

            <TextView
                android:id="@+id/expandable_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/long_text"
                android:textColor="@color/white_blckthme"
                android:textSize="20sp"
                android:maxLines="3"
                android:ellipsize="end" />

            <ImageButton
                android:id="@+id/expand_collapse_btn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@android:drawable/arrow_down_float"
                android:background="@android:color/transparent"
                android:contentDescription="Развернуть" />
        </LinearLayout>


        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:clipChildren="true"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            >
            <WebView
            android:id="@+id/wvMain"
            android:layout_width="match_parent"
            android:layout_height="600dp"
            android:layout_marginTop="-40dp" />
        </FrameLayout>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="что за страна?"
            android:textColor="@color/white_blckthme"/>

        <CheckBox
            android:id="@+id/chk1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Коста-Рика"
            android:textColor="@color/white_blckthme"/>

        <CheckBox
            android:id="@+id/chk2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Испания"
            android:textColor="@color/white_blckthme"/>

        <CheckBox
            android:id="@+id/chk3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Панама"
            android:textColor="@color/white_blckthme"/>

        <!--<CheckBox
            android:id="@+id/chk4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="пример 4"
            android:textColor="@color/txt_color"/>-->

        <Button
            android:id="@+id/btnChoose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:backgroundTint="@color/white_blckthme"
            android:text="Выбор"
            android:textColor="@color/dark_blue"/>

        <TextView
            android:id="@+id/tvChoose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/white_blckthme"
            android:gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Другие кнопки (старая версия)"
            android:textColor="@color/white_blckthme"
            />

        <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:scrollbarSize="10dp"
                android:scrollbarStyle="outsideOverlay"
                >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn2"
                        android:layout_width="150dp"
                        android:layout_height="50dp"
                        android:text="Расписание"
                        android:backgroundTint="#20FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btn3"
                        android:layout_width="150dp"
                        android:layout_height="50dp"
                        android:text="Секундомер"
                        android:backgroundTint="#20FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btn4"
                        android:layout_width="150dp"
                        android:layout_height="50dp"
                        android:text="Плейлист"
                        android:backgroundTint="#20FFFFFF"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnRV"
                        android:layout_width="150dp"
                        android:layout_height="50dp"
                        android:text="Recycle View"
                        android:backgroundTint="#20FFFFFF" />

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </ScrollView>
