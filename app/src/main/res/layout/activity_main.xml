<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://android.com"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="5dp"
    android:background="@drawable/gradient_fon">

    <!-- Картинка по центру -->
    <ImageView
    android:layout_width="200dp"
    android:layout_height="200dp"
    android:src="@drawable/photo"
    android:contentDescription="@string/pht_descr"
    android:layout_marginBottom="32dp"/>

    <!-- ФИО студента сверху по центру жирным -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/my_name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/teal_50"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/descr1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/descr1"
        android:textSize="16sp"
        android:textColor="@color/teal_50"
        android:layout_marginBottom="32dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/nextBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_txt"
        android:textColor="@color/dark_blue"
        android:backgroundTint="@color/white_blckthme"
        />

</LinearLayout>